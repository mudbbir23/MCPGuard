# ============================================
# MCPGuard Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/mcpguard

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# --- Claude API (optional — scanner works without it via pattern-based fallback) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Backend ---
BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Plausible Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mcpguard.dev

# --- Docker Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mcpguard
